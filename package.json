{
  "name": "safekids-check-in",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @safekids/web",
    "build:web": "npm run build --workspace @safekids/web",
    "lint:web": "npm run lint --workspace @safekids/web",
    "typecheck:web": "npm run typecheck --workspace @safekids/web",
    "dev:mobile": "npm run dev --workspace @safekids/mobile",
    "web:mobile": "npm run web --workspace @safekids/mobile",
    "typecheck:mobile": "npm run typecheck --workspace @safekids/mobile",
    "verify": "npm run typecheck:web && npm run typecheck:mobile && npm run build:web"
  }
}
